# KnowledgeFlow AI - Environment Configuration Example
# Copy this file to '.env' and adjust values for your environment.

# ==========================================
# 1. Database Tier Configuration
# ==========================================
# Connection URL for PostgreSQL. In Docker Compose, the db host is 'db'.
DATABASE_URL=postgresql://postgres:postgres@db:5432/knowledgeflow

# Set to true to execute migrations automatically on container start.
DEMO_AUTO_MIGRATION=true

# ==========================================
# 2. Cache & Broker Tier Configuration
# ==========================================
# Connection URL for Redis. In Docker Compose, the redis host is 'redis'.
REDIS_URL=redis://redis:6379/0

# ==========================================
# 3. Application Security & Token Settings
# ==========================================
# Secret key used for signing JWT access tokens. Change this to a secure random key in production!
# Generate using: openssl rand -hex 32
SECRET_KEY=keep-this-secret-and-secure-in-production-deployments

# JWT token expiration time (8 hours)
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ==========================================
# 4. Storage & Ingestion Uploads Settings
# ==========================================
# Base path on disk where uploaded documents are stored.
UPLOAD_DIR=uploads

# ==========================================
# 5. Frontend Environment Configuration
# ==========================================
# Target URL for API fetch queries. In development, defaults to the backend container port.
VITE_API_URL=http://localhost:8000
