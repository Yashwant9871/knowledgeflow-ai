# Python cache and byte-code
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
backend/app/__pycache__/
backend/app/routes/__pycache__/
backend/app/services/__pycache__/
backend/migrations/__pycache__/
backend/migrations/versions/__pycache__/

# Node / Frontend dependencies and outputs
node_modules/
.output/
.nitro/
.wrangler/
dist/
build/
frontend/node_modules/
frontend/.output/
frontend/.nitro/
frontend/.wrangler/

# Virtual Environments
.venv/
venv/
ENV/
env/

# Local configuration files
.env
.env.local
.env.*.local

# IDE and OS files
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp
.DS_Store
Thumbs.db

# Ingestion upload storage
backend/uploads/*
!backend/uploads/.gitkeep
uploads/*
!uploads/.gitkeep
